{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/staybusy/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Nunito, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:now|soft|neutral|success)$/]",
        "message": "<Badge> tone must be one of 'now' | 'soft' | 'neutral' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Block'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|start|end|category|locationName|key|ref|className|style|children)$/]",
        "message": "<Block> doesn't accept that prop. Declared props: title, start, end, category, locationName."
      },
      {
        "selector": "JSXOpeningElement[name.name='Block'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:gig|travel|food|social|work|explore|rest|admin)$/]",
        "message": "<Block> category must be one of 'gig' | 'travel' | 'food' | 'social' | 'work' | 'explore' | 'rest' | 'admin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|fullWidth|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, icon, fullWidth, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: category, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:gig|travel|food|social|work|explore|rest|admin)$/]",
        "message": "<CategoryChip> category must be one of 'gig' | 'travel' | 'food' | 'social' | 'work' | 'explore' | 'rest' | 'admin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayPicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|onChange|style|key|ref|className|style|children)$/]",
        "message": "<DayPicker> doesn't accept that prop. Declared props: date, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|message|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, message, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowNextBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:blocks|now|style|key|ref|className|style|children)$/]",
        "message": "<NowNextBar> doesn't accept that prop. Declared props: blocks, now, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OpenSlotCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:start|end|onClick|style|key|ref|className|style|children)$/]",
        "message": "<OpenSlotCard> doesn't accept that prop. Declared props: start, end, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimeRangeLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:start|end|size|style|key|ref|className|style|children)$/]",
        "message": "<TimeRangeLabel> doesn't accept that prop. Declared props: start, end, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimeRangeLabel'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:caption|title)$/]",
        "message": "<TimeRangeLabel> size must be one of 'caption' | 'title'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
